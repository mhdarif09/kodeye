# Copy to .env.production, replace every change_me value, then chmod 600.
NODE_ENV=production
APP_ENV=production
API_PORT=3001
APP_URL=https://app.kodeye.net
LANDING_URL=https://kodeye.net
PUBLIC_SITE_URL=https://kodeye.net
FRONTEND_URL=https://app.kodeye.net
API_URL=https://backend.kodeye.net
NEXT_PUBLIC_APP_URL=https://app.kodeye.net
NEXT_PUBLIC_LANDING_URL=https://kodeye.net
NEXT_PUBLIC_API_URL=https://backend.kodeye.net/api
CORS_ORIGIN=https://kodeye.net,https://www.kodeye.net,https://app.kodeye.net

DATABASE_URL=mysql://kodeye_user:change_me@mysql:3306/kodeye
MYSQL_DATABASE=kodeye
MYSQL_USER=kodeye_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

JWT_SECRET=change_me_long_random_secret
JWT_EXPIRES_IN=1d
SETTINGS_ENCRYPTION_KEY=
SETTINGS_ENCRYPTION_KEY_VERSION=v1
SETTINGS_CACHE_TTL_SECONDS=60

ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Kodeye Admin
ADMIN_SEED_OVERWRITE=false

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=https://backend.kodeye.net/api/auth/github/callback
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_INSTALL_URL=
GITHUB_APP_CALLBACK_URL=https://backend.kodeye.net/api/github/install/callback
GITHUB_WEBHOOK_ENABLED=true
AUTO_SCAN_PUSH_ENABLED=true
AUTO_SCAN_PULL_REQUEST_ENABLED=true
GITHUB_CHECK_NAME=Kodeye Security Scan
GITHUB_CHECK_DETAILS_BASE_URL=https://app.kodeye.net/dashboard/scans
FRONTEND_AUTH_CALLBACK_URL=https://app.kodeye.net/auth/callback
FRONTEND_GITHUB_INTEGRATION_URL=https://app.kodeye.net/dashboard/integrations/github

SCAN_WORKER_ENABLED=true
SCAN_WORKER_POLL_INTERVAL_MS=5000
SCAN_WORKER_MAX_CONCURRENCY=1
SCAN_WORKER_TEMP_DIR=/tmp/kodeye/scans
SCANNER_EXECUTION_MODE=local-cli
SCANNER_SEMGREP_BIN=semgrep
SCANNER_GITLEAKS_BIN=gitleaks
SCANNER_TRIVY_BIN=trivy
SCANNER_TIMEOUT_MS=300000

REPORT_STORAGE_DIR=/app/storage/reports
REPORT_ENABLE_PDF=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
INVOICE_STORAGE_DIR=/app/storage/invoices
INVOICE_PDF_ENABLED=true

BILLING_TAX_ENABLED=true
BILLING_DEFAULT_TAX_RATE=0.11
BILLING_TAX_LABEL=PPN
BILLING_DEFAULT_CURRENCY=IDR
BILLING_SUPPORTED_CURRENCIES=IDR,USD,EUR,SGD
BILLING_USE_LIVE_CURRENCY=true
BILLING_EXCHANGE_RATE_PROVIDER=frankfurter
BILLING_EXCHANGE_RATE_CACHE_TTL_HOURS=24
BILLING_ALLOW_STALE_EXCHANGE_RATE=true

MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_NOTIFICATION_SECRET=

PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SUPPORTED_CURRENCIES=USD,EUR,SGD

PAYMENT_SUCCESS_URL=https://app.kodeye.net/dashboard/billing?status=success
PAYMENT_PENDING_URL=https://app.kodeye.net/dashboard/billing?status=pending
PAYMENT_ERROR_URL=https://app.kodeye.net/dashboard/billing?status=error
FRONTEND_BILLING_URL=https://app.kodeye.net/dashboard/billing

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
