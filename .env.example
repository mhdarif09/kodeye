DATABASE_URL="mysql://root:@localhost:3306/kodeye"
API_PORT=3001
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"
REQUIRE_HTTPS=false
API_DOCS_ENABLED=true
API_MAX_BODY_BYTES=1048576
JWT_SECRET="change-this-secret-in-local-env"
JWT_EXPIRES_IN="1d"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

ADMIN_SEED_EMAIL="admin@kodeye.net"
ADMIN_SEED_PASSWORD="password123"
ADMIN_SEED_NAME="Kodeye Admin"
ADMIN_SEED_OVERWRITE=false

SETTINGS_ENCRYPTION_KEY="12345678901234567890123456789012"
SETTINGS_ENCRYPTION_KEY_VERSION="v1"
SETTINGS_CACHE_TTL_SECONDS=60
