DATABASE_URL="mysql://root:@localhost:3306/kodeye"
API_PORT=3001
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"
REQUIRE_HTTPS=false
API_DOCS_ENABLED=true
API_MAX_BODY_BYTES=1048576
JWT_SECRET="change-this-secret-in-local-env"
JWT_EXPIRES_IN="1d"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""
GITHUB_OAUTH_CALLBACK_URL="http://localhost:3001/api/auth/github/callback"

GITHUB_APP_ID=""
GITHUB_APP_NAME=""
GITHUB_APP_PRIVATE_KEY_PATH="./kodeye-local.private-key.pem"
GITHUB_APP_WEBHOOK_SECRET=""
GITHUB_CHECK_NAME="Kodeye Security Scan"
GITHUB_WEBHOOK_ENABLED=true
AUTO_SCAN_PUSH_ENABLED=true
AUTO_SCAN_PULL_REQUEST_ENABLED=true
GITHUB_CHECK_DETAILS_BASE_URL="http://localhost:3000/dashboard/scans"
GITHUB_APP_INSTALL_URL=""
GITHUB_APP_CALLBACK_URL="http://localhost:3001/api/github/install/callback"

FRONTEND_AUTH_CALLBACK_URL="http://localhost:3000/auth/callback"
FRONTEND_GITHUB_INTEGRATION_URL="http://localhost:3000/dashboard/integrations/github"

SCAN_WORKER_ENABLED=false
AUTO_SCAN_ON_SYNC_ENABLED=true
SCAN_WORKER_POLL_INTERVAL_MS=5000
SCAN_WORKER_MAX_CONCURRENCY=1
SCAN_WORKER_TEMP_DIR="./tmp/scans"
SCANNER_EXECUTION_MODE="disabled"

SCANNER_CODEQL_BIN="codeql"
SCANNER_CODEQL_LANGUAGES="javascript-typescript,python,go,java-kotlin,csharp,ruby"
SCANNER_CODEQL_QUERIES=""
SCANNER_SEMGREP_BIN="semgrep"
SCANNER_SEMGREP_CONFIGS="p/default,p/security-audit,p/owasp-top-ten,p/cwe-top-25,p/secrets"
SCANNER_SEMGREP_INCLUDE_IGNORED=true
SCANNER_SEMGREP_JOBS=4
SCANNER_SEMGREP_MAX_TARGET_BYTES=1000000
SCANNER_SEMGREP_PRO=false
SCANNER_SEMGREP_TIMEOUT_SECONDS=60
SCANNER_GITLEAKS_BIN="gitleaks"
SCANNER_TRIVY_BIN="trivy"
SCANNER_TRIVY_SCANNERS="vuln,misconfig,secret"
SCANNER_STORE_CODE_EVIDENCE=false
SCANNER_TIMEOUT_MS=900000

AI_ENABLED=false
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
AI_MAX_COMPLETION_TOKENS=1200
AI_REQUEST_TIMEOUT_MS=30000
AI_FIX_MAX_COMPLETION_TOKENS=16000
AI_FIX_MAX_FILE_BYTES=30000
AI_GITHUB_WRITE_ENABLED=false

REPORT_STORAGE_DIR="./tmp/reports"
WORKSPACE_STORAGE_DIR="./tmp/workspaces"
REPORT_ENABLE_PDF=true
PUPPETEER_EXECUTABLE_PATH=""

BILLING_TAX_ENABLED=true
BILLING_DEFAULT_TAX_RATE=0.11
BILLING_TAX_LABEL="PPN"
BILLING_DEFAULT_CURRENCY="IDR"
BILLING_SUPPORTED_CURRENCIES="IDR,USD,EUR,SGD"
BILLING_USE_LIVE_CURRENCY=true
BILLING_EXCHANGE_RATE_PROVIDER="frankfurter"
BILLING_EXCHANGE_RATE_CACHE_TTL_HOURS=24
BILLING_ALLOW_STALE_EXCHANGE_RATE=true
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_MERCHANT_ID=""
MIDTRANS_NOTIFICATION_SECRET=""
PAYPAL_ENVIRONMENT="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_SUPPORTED_CURRENCIES="USD,EUR,SGD"
PAYMENT_SUCCESS_URL="http://localhost:3000/payments/paypal/return"
PAYMENT_PENDING_URL="http://localhost:3000/dashboard/billing?status=pending"
PAYMENT_ERROR_URL="http://localhost:3000/payments/paypal/cancel"
FRONTEND_BILLING_URL="http://localhost:3000/dashboard/billing"
ADMIN_SEED_EMAIL=""
ADMIN_SEED_PASSWORD=""
ADMIN_SEED_NAME="Kodeye Admin"
ADMIN_SEED_OVERWRITE=false

# Keep this boot-critical key in environment. Dashboard-managed secrets are
# encrypted with it. Production requires a valid 32-byte/base64/hex key.
SETTINGS_ENCRYPTION_KEY=""
SETTINGS_ENCRYPTION_KEY_VERSION="v1"
SETTINGS_CACHE_TTL_SECONDS=60
INVOICE_STORAGE_DIR="./tmp/invoices"
INVOICE_PDF_ENABLED=true
