    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.4.1",
    "typescript": "^5.8.2",
    "tsx": "^4.19.3"
