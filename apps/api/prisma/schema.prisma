generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET
}

enum SettingCategory {
  APP
  GITHUB
  MIDTRANS
  PAYPAL
  BILLING
  CURRENCY
  SCANNER
  REPORT
  INVOICE
  SECURITY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CLEAR_SECRET
  TEST_CONNECTION
  LOGIN_AS_ADMIN
  SETTINGS_RELOAD
}

enum SalesInquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

model User {
  id           String     @id @default(cuid())
  name         String     @db.VarChar(255)
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  suspendedAt  DateTime?  @map("suspended_at")
  deletedAt    DateTime?  @map("deleted_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  updatedSystemSettings SystemSetting[]
  updatedSettings       AppSetting[]
  adminAuditLogs        AdminAuditLog[]
  blogPosts             BlogPost[]

  @@map("users")
}

model SystemSetting {
  id              String   @id @default(cuid())
  key             String   @unique @db.VarChar(150)
  encryptedValue  String   @map("encrypted_value") @db.LongText
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedBy       User?    @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
  @@map("system_settings")
}

model AppSetting {
  id              String           @id @default(cuid())
  key             String           @unique @db.VarChar(255)
  category        SettingCategory
  valueType       SettingValueType @map("value_type")
  value           String?          @db.Text
  encryptedValue  String?          @map("encrypted_value") @db.Text
  encryptionIv    String?          @map("encryption_iv") @db.VarChar(255)
  encryptionTag   String?          @map("encryption_tag") @db.VarChar(255)
  keyVersion      String?          @map("key_version") @db.VarChar(50)
  isSecret        Boolean          @default(false) @map("is_secret")
  isActive        Boolean          @default(true) @map("is_active")
  description     String?          @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  updatedByUserId String?          @map("updated_by_user_id")
  updatedBy       User?            @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([updatedByUserId])
  @@map("app_settings")
}

model AdminAuditLog {
  id           String      @id @default(cuid())
  actorUserId  String?     @map("actor_user_id")
  action       AuditAction
  resourceType String      @map("resource_type") @db.VarChar(100)
  resourceId   String?     @map("resource_id") @db.VarChar(255)
  resourceKey  String?     @map("resource_key") @db.VarChar(255)
  ipAddress    String?     @map("ip_address") @db.VarChar(100)
  userAgent    String?     @map("user_agent") @db.Text
  metadataJson Json?       @map("metadata_json")
  createdAt    DateTime    @default(now()) @map("created_at")
  actor        User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([resourceType])
  @@index([resourceKey])
  @@map("admin_audit_logs")
}

model BlogPost {
  id              String         @id @default(cuid())
  authorUserId    String?        @map("author_user_id")
  title           String         @db.VarChar(255)
  slug            String         @unique @db.VarChar(255)
  excerpt         String         @db.VarChar(500)
  content         String         @db.LongText
  status          BlogPostStatus @default(DRAFT)
  metaTitle       String?        @map("meta_title") @db.VarChar(255)
  metaDescription String?        @map("meta_description") @db.VarChar(500)
  publishedAt     DateTime?      @map("published_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  author User? @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([authorUserId])
  @@index([status, publishedAt])
  @@map("blog_posts")
}

model SalesInquiry {
  id          String             @id @default(cuid())
  name        String             @db.VarChar(255)
  email       String             @db.VarChar(255)
  companyName String             @map("company_name") @db.VarChar(255)
  phone       String?            @db.VarChar(100)
  service     String             @db.VarChar(120)
  budget      String?            @db.VarChar(120)
  timeline    String?            @db.VarChar(120)
  message     String             @db.Text
  source      String             @default("contact-sales") @db.VarChar(120)
  status      SalesInquiryStatus @default(NEW)
  adminNote   String?            @map("admin_note") @db.Text
  contactedAt DateTime?          @map("contacted_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([service])
  @@map("sales_inquiries")
}

model PortfolioProject {
  id         String   @id @default(cuid())
  title      String   @db.VarChar(255)
  subtitle   String   @db.VarChar(255)
  category   String   @default("Website Development") @db.VarChar(100)
  imageUrl   String   @map("image_url") @db.VarChar(2048)
  projectUrl String?  @map("project_url") @db.VarChar(2048)
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("portfolio_projects")
}

model TeamMember {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(255)
  role         String   @db.VarChar(255)
  description  String   @db.Text
  photoUrl     String   @map("photo_url") @db.VarChar(2048)
  linkedinUrl  String?  @map("linkedin_url") @db.VarChar(2048)
  githubUrl    String?  @map("github_url") @db.VarChar(2048)
  instagramUrl String?  @map("instagram_url") @db.VarChar(2048)
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("team_members")
}

model TrustedCompany {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(255)
  logoUrl    String   @map("logo_url") @db.VarChar(2048)
  websiteUrl String?  @map("website_url") @db.VarChar(2048)
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("trusted_companies")
}
